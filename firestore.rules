rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------------
    // User document — basic profile (optional future use)
    // ---------------------------------------------------------------------------
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // ---------------------------------------------------------------------------
      // FundState — single active document per user
      // ---------------------------------------------------------------------------
      match /fund_state/{document} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId
                           && isValidFundState();
      }

      // ---------------------------------------------------------------------------
      // Ledger entries — paginated, reverse-chron
      // ---------------------------------------------------------------------------
      match /ledger_entries/{entryId} {
        allow read: if request.auth != null && request.auth.uid == userId;

        allow create: if request.auth != null
                      && request.auth.uid == userId
                      && isValidLedgerEntry();

        allow update: if request.auth != null
                      && request.auth.uid == userId
                      && isValidLedgerEntry();

        allow delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ---------------------------------------------------------------------------
    // Validation helpers
    // ---------------------------------------------------------------------------

    function isValidFundState() {
      let data = request.resource.data;
      return data.keys().hasAll(['principalAmount', 'lockedAmount', 'spendableAmount', 'lastUpdated'])
          && data.principalAmount is number
          && data.principalAmount >= 0
          && data.lockedAmount is number
          && data.lockedAmount >= 0
          && data.lockedAmount <= data.principalAmount
          && data.spendableAmount is number
          && data.lastUpdated is string;
    }

    function isValidLedgerEntry() {
      let data = request.resource.data;
      let validTypes = ['expense', 'fund_update'];
      return data.keys().hasAll(['type', 'amount', 'timestamp', 'balanceAfter'])
          && data.type in validTypes
          && data.amount is number
          && data.amount >= 0
          && data.timestamp is string
          && data.balanceAfter is number;
    }

    // ---------------------------------------------------------------------------
    // Deny all other paths by default
    // ---------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
